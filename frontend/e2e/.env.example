# Copy to e2e/.env (or set in shell) before running Playwright.

# Frontend (Vite dev server)
E2E_BASE_URL=http://localhost:5173

# Fleetbase API (must be running — Docker on :8000)
E2E_API_URL=http://localhost:8000
E2E_API_NAMESPACE=int/v1

# Admin credentials (identity = email)
E2E_USER_EMAIL=admin@techliv.net
E2E_USER_PASSWORD=your-password-here

# Optional: slow motion for headed demos (ms per action)
# E2E_SLOW_MO=100

# Optional: skip tests that mutate production-like data
# E2E_ALLOW_DESTRUCTIVE=false
