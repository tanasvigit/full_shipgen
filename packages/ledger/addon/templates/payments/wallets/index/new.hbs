<Layout::Resource::Panel
    @resource={{this.wallet}}
    @controller={{this}}
    @headerTitle="Create New Wallet"
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "payments.wallets.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Wallet::Form @resource={{this.wallet}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>