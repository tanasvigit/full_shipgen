<Layout::Resource::Panel
    @resource={{this.gateway}}
    @controller={{this}}
    @headerTitle="Add New Gateway"
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "payments.gateways.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Gateway::Form @resource={{this.gateway}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>