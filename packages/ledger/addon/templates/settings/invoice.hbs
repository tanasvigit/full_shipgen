<Layout::Section::Header @title="Invoice Settings">
    <Button
        @type="primary"
        @size="sm"
        @icon="save"
        @text="Save Changes"
        @onClick={{perform this.saveSettings}}
        @disabled={{this.saveSettings.isRunning}}
        @isLoading={{or this.saveSettings.isRunning this.getSettings.isRunning}}
    />
</Layout::Section::Header>

<Layout::Section::Body class="overflow-y-scroll h-full">
    <div class="container mx-auto h-screen">
        <div class="max-w-3xl my-10 mx-auto space-y-6">

            {{! ── Numbering ──────────────────────────────────────────────────── }}
            <ContentPanel @title="Invoice Numbering" @open={{true}} @wrapperClass="bordered-classic">
                <InputGroup @name="Invoice Number Prefix" @helpText="This prefix is prepended to every new invoice number, e.g. 'INV-000001'.">
                    <Input @value={{this.invoice_prefix}} @type="text" class="w-full form-input" placeholder="INV" />
                </InputGroup>
            </ContentPanel>

            {{! ── Currency & Payment Terms ────────────────────────────────────── }}
            <ContentPanel @title="Currency & Payment Terms" @open={{true}} @wrapperClass="bordered-classic">
                <InputGroup @name="Default Currency" @helpText="The currency applied to new invoices unless overridden on the invoice itself.">
                    <CurrencySelect
                        @currency={{this.effectiveCurrency}}
                        @currencyData={{this.selectedCurrency}}
                        @onCurrencyChange={{this.onSelectCurrency}}
                        @triggerClass="form-select form-input"
                        @placeholder={{concat "Default: " this.companyCurrency}}
                        @allowClear={{true}}
                    />
                    {{#unless this.default_currency}}
                        <p class="text-xs text-gray-400 mt-1">Using organisation default ({{this.companyCurrency}}). Select a currency above to override.</p>
                    {{/unless}}
                </InputGroup>

                <InputGroup @name="Default Payment Terms" @helpText="Number of days after the invoice date that payment is due.">
                    <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                        <PowerSelect
                            @options={{this.paymentTermsOptions}}
                            @selected={{find-by "value" this.payment_terms_days this.paymentTermsOptions}}
                            @onChange={{this.onSelectPaymentTerms}}
                            @placeholder="Select payment terms"
                            @triggerClass="form-select form-input"
                            as |opt|
                        >
                            <div class="text-sm">{{opt.label}}</div>
                        </PowerSelect>
                    </div>
                </InputGroup>
            </ContentPanel>

            {{! ── Default Text ─────────────────────────────────────────────────── }}
            <ContentPanel @title="Default Invoice Text" @open={{true}} @wrapperClass="bordered-classic">
                <InputGroup @name="Default Notes" @helpText="These notes appear at the bottom of every new invoice. You can override them per invoice.">
                    <Textarea @value={{this.default_notes}} class="w-full form-input" rows="3" placeholder="e.g. Thank you for your business!" />
                </InputGroup>

                <InputGroup @name="Default Terms & Conditions" @helpText="Standard terms pre-filled on every new invoice.">
                    <Textarea @value={{this.default_terms}} class="w-full form-input" rows="3" placeholder="e.g. Payment is due within 30 days of the invoice date." />
                </InputGroup>
            </ContentPanel>

            {{! ── Default Template ─────────────────────────────────────────────── }}
            <ContentPanel @title="Default Invoice Template" @open={{true}} @wrapperClass="bordered-classic">
                <InputGroup
                    @name="Default Template"
                    @helpText="The invoice template applied to all new invoices, including those auto-generated from Fleet-Ops orders. Leave blank to use the system default."
                >
                    <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                        <PowerSelect
                            @options={{this.availableTemplates}}
                            @selected={{this.selectedTemplate}}
                            @onChange={{this.onSelectDefaultTemplate}}
                            @placeholder="Select an invoice template"
                            @triggerClass="form-select form-input"
                            @allowClear={{true}}
                            as |template|
                        >
                            <div class="text-sm">{{template.name}}</div>
                        </PowerSelect>
                    </div>
                    {{#if this.selectedTemplate}}
                        <div class="mt-1 text-[11px] text-gray-500">
                            Selected:
                            <span class="font-medium">{{this.selectedTemplate.name}}</span>
                        </div>
                    {{/if}}
                    {{#unless this.availableTemplates.length}}
                        <div class="mt-1 text-[11px] text-amber-600">
                            No invoice templates found.
                            <LinkTo @route="billing.invoice-templates.index.new" class="underline">Create a template</LinkTo>
                            to enable custom invoice branding.
                        </div>
                    {{/unless}}
                </InputGroup>
            </ContentPanel>

            {{! ── Automation ───────────────────────────────────────────────────── }}
            <ContentPanel @title="Automation" @open={{true}} @wrapperClass="bordered-classic">
                <InputGroup @name="Auto-Send on Creation">
                    <Toggle
                        @isToggled={{this.auto_send_on_creation}}
                        @label="Automatically email the invoice to the customer when it is created."
                        @onToggle={{fn (mut this.auto_send_on_creation)}}
                    />
                </InputGroup>
            </ContentPanel>

        </div>
    </div>
    <Spacer @height="600px" />
</Layout::Section::Body>