{{#if this.invoice}}
    <Layout::Resource::Panel
        @resource={{this.invoice}}
        @controller={{this}}
        @headerTitle="Create New Invoice"
        @actionButtons={{this.actionButtons}}
        @saveTask={{this.save}}
        @onPressCancel={{transition-to "billing.invoices.index"}}
        @onOverlayReady={{fn (mut this.overlay)}}
        @width="900px"
    >
        <Invoice::Form @resource={{this.invoice}} @controller={{this}} @registerRef={{this.registerFormRef}} />
        <Spacer @height="200px" />
    </Layout::Resource::Panel>
{{else}}
    <div class="flex items-center justify-center p-8">
        <Spinner />
    </div>
{{/if}}