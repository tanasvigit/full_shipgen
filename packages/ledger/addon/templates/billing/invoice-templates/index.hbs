<Layout::Resource::Tabular
    @resource="template"
    @title="Invoice Templates"
    @searchQuery={{this.query}}
    @onSearch={{fn (mut this.query)}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @setupTable={{fn (mut this.table)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
/>

{{! Wormhole target for the full-viewport template builder.
    The new/edit child routes teleport their <TemplateBuilder> here so it
    covers the entire viewport rather than rendering inline inside the table. }}
<div id="ledger-template-builder-outlet" class="ledger-template-builder-outlet"></div>

{{outlet}}