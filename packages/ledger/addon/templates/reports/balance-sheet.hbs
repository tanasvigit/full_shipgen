<Layout::Section::Header @title="Balance Sheet" @actionsWrapperClass="flex flex-row items-center space-x-2">
    <div class="flex flex-row items-center space-x-2">
        <DatePicker @value={{this.as_of}} @onSelect={{this.onDateChanged}} @autoClose={{true}} @buttons={{array "clear"}} @placeholder="As of date" class="w-44 form-input form-input-sm" />
        <Button @size="sm" @type="default" @icon="refresh" @helpText="Refresh" {{on "click" this.reload}} />
    </div>
</Layout::Section::Header>
<Layout::Section::Body class="overflow-y-auto h-full">
    <div class="p-6">
        {{#if this.loadReport.isRunning}}
            <div class="flex items-center justify-center py-20"><Spinner /></div>
        {{else if this.data}}
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Balance Sheet</h2>
                    {{#if this.data.as_of_date}}
                        <p class="text-sm text-gray-500 mt-0.5">As of {{format-date-fns this.data.as_of_date "MMMM d, yyyy"}}</p>
                    {{/if}}
                </div>
                <Badge @color={{if this.data.balanced "green" "red"}}>{{if this.data.balanced "Balanced" "Unbalanced"}}</Badge>
            </div>
            {{#each
                (array
                    (hash label="Assets" items=this.data.assets total=this.data.total_assets)
                    (hash label="Liabilities" items=this.data.liabilities total=this.data.total_liabilities)
                    (hash label="Equity" items=this.data.equity total=this.data.total_equity)
                )
                as |section|
            }}
                <div class="mb-6 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                    <div class="bg-gray-50 dark:bg-gray-800 px-4 py-2 border-b border-gray-200 dark:border-gray-700">
                        <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">{{section.label}}</h3>
                    </div>
                    <table class="w-full text-sm overflow-hidden">
                        <tbody>
                            {{#each section.items as |item|}}
                                <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-800">
                                    <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{item.name}}</td>
                                    <td class="px-4 py-2 text-xs text-gray-400 font-mono">{{item.code}}</td>
                                    <td class="px-4 py-2 text-right font-medium text-gray-900 dark:text-white">{{format-currency item.balance this.companyCurrency}}</td>
                                </tr>
                            {{else}}
                                <tr><td colspan="3" class="px-4 py-3 text-center text-gray-400 text-xs">No {{section.label}} accounts</td></tr>
                            {{/each}}
                        </tbody>
                        <tfoot>
                            <tr class="bg-gray-50 dark:bg-gray-800 border-t-2 border-gray-300 dark:border-gray-700">
                                <td colspan="2" class="px-4 py-2.5 font-semibold text-gray-900 dark:text-white">Total {{section.label}}</td>
                                <td class="px-4 py-2.5 text-right font-bold text-gray-900 dark:text-white">{{format-currency section.total this.companyCurrency}}</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            {{/each}}
            <div class="border-t-2 border-gray-400 dark:border-gray-700 pt-4">
                <div class="flex justify-between items-center py-1">
                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Total Liabilities &amp; Equity</span>
                    <span class="text-sm font-bold text-gray-900 dark:text-white">{{format-currency this.data.total_liabilities_and_equity this.companyCurrency}}</span>
                </div>
            </div>
        {{else}}
            <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                <p class="text-sm">No report data available. Select a date and refresh.</p>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>