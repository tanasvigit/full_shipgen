<Layout::Section::Header @title="Trial Balance" @actionsWrapperClass="flex flex-row items-center space-x-2">
    <div class="flex flex-row items-center space-x-2">
        <DatePicker @value={{this.as_of}} @onSelect={{this.onDateChanged}} @autoClose={{true}} @buttons={{array "clear"}} @placeholder="As of date" class="w-44 form-input form-input-sm" />
        <Button @size="sm" @type="default" @icon="refresh" @helpText="Refresh" {{on "click" this.reload}} />
    </div>
</Layout::Section::Header>
<Layout::Section::Body class="overflow-y-auto h-full">
    <div class="p-6">
        {{#if this.loadReport.isRunning}}
            <div class="flex items-center justify-center py-20"><Spinner /></div>
        {{else if this.data}}
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Trial Balance</h2>
                    {{#if this.data.as_of_date}}
                        <p class="text-sm text-gray-500 mt-0.5">As of {{format-date-fns this.data.as_of_date "MMMM d, yyyy"}}</p>
                    {{/if}}
                </div>
                <Badge @color={{if this.data.balanced "green" "red"}}>{{if this.data.balanced "Balanced" "Unbalanced"}}</Badge>
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <table class="w-full text-sm overflow-hidden">
                    <thead>
                        <tr class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Code</th>
                            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Account</th>
                            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
                            <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Debit</th>
                            <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Credit</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each this.data.accounts as |row|}}
                            <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-800">
                                <td class="px-4 py-2 font-mono text-xs text-gray-400">{{row.code}}</td>
                                <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{row.name}}</td>
                                <td class="px-4 py-2">
                                    <Badge @color="blue">{{row.type}}</Badge>
                                </td>
                                <td class="px-4 py-2 text-right font-medium text-gray-900 dark:text-white">
                                    {{#if row.debit}}{{format-currency row.debit this.companyCurrency}}{{else}}—{{/if}}
                                </td>
                                <td class="px-4 py-2 text-right font-medium text-gray-900 dark:text-white">
                                    {{#if row.credit}}{{format-currency row.credit this.companyCurrency}}{{else}}—{{/if}}
                                </td>
                            </tr>
                        {{else}}
                            <tr><td colspan="5" class="px-4 py-6 text-center text-gray-400 text-sm">No account data available</td></tr>
                        {{/each}}
                    </tbody>
                    <tfoot>
                        <tr class="bg-gray-50 dark:bg-gray-800 border-t-2 border-gray-300 dark:border-gray-700">
                            <td colspan="3" class="px-4 py-2.5 font-semibold text-gray-900 dark:text-white">Totals</td>
                            <td class="px-4 py-2.5 text-right font-bold text-gray-900 dark:text-white">{{format-currency this.data.total_debits this.companyCurrency}}</td>
                            <td class="px-4 py-2.5 text-right font-bold text-gray-900 dark:text-white">{{format-currency this.data.total_credits this.companyCurrency}}</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        {{else}}
            <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                <p class="text-sm">No report data available. Select a date and refresh.</p>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>