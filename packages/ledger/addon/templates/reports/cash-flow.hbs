<Layout::Section::Header @title="Cash Flow" @actionsWrapperClass="flex flex-row items-center space-x-2">
    <div class="flex flex-row items-center space-x-2">
        <DatePicker
            @value={{this.dateRange}}
            @range={{true}}
            @onSelect={{this.onDateRangeChanged}}
            @autoClose={{true}}
            @buttons={{array "clear"}}
            @placeholder="Select period"
            class="w-52 form-input form-input-sm"
        />
        <Button @size="sm" @type="default" @icon="refresh" @helpText="Refresh" {{on "click" this.reload}} />
    </div>
</Layout::Section::Header>
<Layout::Section::Body class="overflow-y-auto h-full">
    <div class="p-6">
        {{#if this.loadReport.isRunning}}
            <div class="flex items-center justify-center py-20"><Spinner /></div>
        {{else if this.data}}
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Cash Flow Statement</h2>
                    {{#if this.data.period}}
                        <p class="text-sm text-gray-500 mt-0.5">{{this.data.period}}</p>
                    {{/if}}
                </div>
            </div>

            {{! Operating Activities }}
            <div class="mb-6 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <div class="bg-gray-50 dark:bg-gray-800 px-4 py-2 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Operating Activities</h3>
                </div>
                <table class="w-full text-sm overflow-hidden">
                    <tbody>
                        {{#each this.data.operating as |item|}}
                            <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-800">
                                <td class="px-4 py-2 text-gray-700 dark:text-gray-300 capitalize">{{item.type}}</td>
                                <td class="px-4 py-2 text-right font-medium {{if (gt item.net 0) 'text-green-600 dark:text-green-400' 'text-red-600 dark:text-red-400'}}">
                                    {{format-currency item.net (or item.currency this.companyCurrency)}}
                                </td>
                            </tr>
                        {{else}}
                            <tr><td colspan="2" class="px-4 py-3 text-center text-gray-400 text-xs">No operating activity data</td></tr>
                        {{/each}}
                    </tbody>
                    <tfoot>
                        <tr class="bg-gray-50 dark:bg-gray-800 border-t-2 border-gray-300 dark:border-gray-700">
                            <td class="px-4 py-2.5 font-semibold text-gray-900 dark:text-white">Net Operating Cash Flow</td>
                            <td class="px-4 py-2.5 text-right font-bold {{if (gt this.data.net_operating 0) 'text-green-600 dark:text-green-400' 'text-red-600 dark:text-red-400'}}">
                                {{format-currency this.data.net_operating this.companyCurrency}}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            {{! Financing Activities }}
            <div class="mb-6 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <div class="bg-gray-50 dark:bg-gray-800 px-4 py-2 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Financing Activities</h3>
                </div>
                <table class="w-full text-sm overflow-hidden">
                    <tbody>
                        {{#each this.data.financing as |item|}}
                            <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-800">
                                <td class="px-4 py-2 text-gray-700 dark:text-gray-300 capitalize">{{item.type}}</td>
                                <td class="px-4 py-2 text-right font-medium {{if (gt item.net 0) 'text-green-600 dark:text-green-400' 'text-red-600 dark:text-red-400'}}">
                                    {{format-currency item.net (or item.currency this.companyCurrency)}}
                                </td>
                            </tr>
                        {{else}}
                            <tr><td colspan="2" class="px-4 py-3 text-center text-gray-400 text-xs">No financing activity data</td></tr>
                        {{/each}}
                    </tbody>
                    <tfoot>
                        <tr class="bg-gray-50 dark:bg-gray-800 border-t-2 border-gray-300 dark:border-gray-700">
                            <td class="px-4 py-2.5 font-semibold text-gray-900 dark:text-white">Net Financing Cash Flow</td>
                            <td class="px-4 py-2.5 text-right font-bold {{if (gt this.data.net_financing 0) 'text-green-600 dark:text-green-400' 'text-red-600 dark:text-red-400'}}">
                                {{format-currency this.data.net_financing this.companyCurrency}}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            {{! Net Change in Cash }}
            <div class="border-t-2 border-gray-400 dark:border-gray-700 pt-4">
                <div class="flex justify-between items-center py-1">
                    <span class="text-base font-bold text-gray-900 dark:text-white">Net Change in Cash</span>
                    <span class="text-base font-bold {{if (gt this.data.net_change 0) 'text-green-600 dark:text-green-400' 'text-red-600 dark:text-red-400'}}">
                        {{format-currency this.data.net_change this.companyCurrency}}
                    </span>
                </div>
            </div>
        {{else}}
            <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                <p class="text-sm">No report data available. Select a period and refresh.</p>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>