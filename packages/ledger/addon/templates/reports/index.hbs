<Layout::Section::Header @title="Reports" @hideActions={{true}} />
<Layout::Section::Body>
    <div class="p-4 space-y-4">
        {{! Report selector tabs }}
        <div class="flex items-center space-x-1 border-b border-gray-200 dark:border-gray-700 pb-3">
            {{#each this.reportTabs as |tab|}}
                <button
                    type="button"
                    class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors
                        {{if
                            (eq this.activeReport tab.id)
                            'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400'
                            'text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700'
                        }}"
                    {{on "click" (fn this.selectReport tab.id)}}
                >
                    {{tab.label}}
                </button>
            {{/each}}
            <div class="flex-1"></div>
            <Button @type="primary" @size="sm" {{on "click" this.runReport}}>
                <FaIcon @icon="play" class="mr-1" />
                Run Report
            </Button>
        </div>

        {{! Report content }}
        {{#if this.isLoading}}
            <div class="flex items-center justify-center py-20"><Spinner /></div>
        {{else if this.reportData}}
            {{#if (eq this.activeReport "balance-sheet")}}
                <Report::BalanceSheet @data={{this.reportData}} />
            {{else if (eq this.activeReport "income-statement")}}
                <Report::IncomeStatement @data={{this.reportData}} />
            {{else if (eq this.activeReport "cash-flow")}}
                <Report::CashFlow @data={{this.reportData}} />
            {{else if (eq this.activeReport "ar-aging")}}
                <Report::ArAging @data={{this.reportData}} />
            {{/if}}
        {{else}}
            <div class="flex flex-col items-center justify-center py-16 text-gray-400">
                <FaIcon @icon="file-contract" class="w-12 h-12 mb-3 opacity-30" />
                <p class="text-sm">Select a report and click "Run Report" to generate it.</p>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>