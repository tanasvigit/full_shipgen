<Layout::Section::Header @title="General Ledger" @actionsWrapperClass="flex flex-row items-center space-x-2">
    <div class="general-ledger-filters flex flex-row items-center space-x-2">
        <DatePicker
            @value={{this.dateRange}}
            @range={{true}}
            @onSelect={{this.onDateRangeChanged}}
            @autoClose={{true}}
            @buttons={{array "clear"}}
            @placeholder="Select date range"
            class="w-52"
        />
        <div class="fleetbase-model-select fleetbase-power-select ember-model-select w-40">
            <PowerSelect
                @options={{this.accountTypes}}
                @selected={{this.selectedType}}
                @onChange={{this.setType}}
                @searchEnabled={{false}}
                @triggerClass="form-select form-input"
                @renderInPlace={{true}}
                as |opt|
            >
                {{opt.label}}
            </PowerSelect>
        </div>
        <Button
            @size="sm"
            @type="default"
            @icon={{if this.allExpanded "chevron-up" "chevron-down"}}
            @helpText={{if this.allExpanded "Collapse All" "Expand All"}}
            {{on "click" this.toggleExpandAll}}
        />
    </div>
</Layout::Section::Header>
<Layout::Section::Body class="overflow-y-scroll h-full">
    <div class="p-4 space-y-4">

        {{! ── Account list ─────────────────────────────────────────────────── }}
        {{#if this.loadGeneralLedger.isRunning}}
            <div class="flex items-center justify-center py-20">
                <Spinner />
            </div>
        {{else if this.accounts.length}}
            {{#each this.accounts as |row|}}
                {{#let row.account as |acct|}}
                    <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">

                        {{! Account header row — click to expand/collapse }}
                        <button
                            type="button"
                            class="w-full flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-left"
                            {{on "click" (fn this.toggleAccount acct.id)}}
                        >
                            <div class="flex items-center gap-3">
                                <FaIcon @icon={{if (get this.expandedMap acct.id) "chevron-down" "chevron-right"}} class="text-gray-400 w-3 h-3" />
                                <span class="text-xs font-mono text-gray-500 dark:text-gray-400">{{acct.code}}</span>
                                <span class="text-sm font-semibold text-gray-900 dark:text-white">{{acct.name}}</span>
                                <Badge class="capitalize text-xs">{{acct.type}}</Badge>
                            </div>
                            <div class="flex items-center gap-6 text-right">
                                {{#if row.summary.entry_count}}
                                    <span class="text-xs text-gray-400">{{row.summary.entry_count}} entries</span>
                                {{/if}}
                                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                                    {{format-currency row.summary.net_balance acct.currency}}
                                </div>
                            </div>
                        </button>

                        {{! Entry table — shown when expanded }}
                        {{#if (get this.expandedMap acct.id)}}
                            {{#if row.entries.length}}
                                <div class="overflow-x-auto">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
                                                <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 uppercase">Date</th>
                                                <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 uppercase">Ref #</th>
                                                <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 uppercase">Description</th>
                                                <th class="text-right px-4 py-2 text-xs font-medium text-gray-500 uppercase">Debit</th>
                                                <th class="text-right px-4 py-2 text-xs font-medium text-gray-500 uppercase">Credit</th>
                                                <th class="text-right px-4 py-2 text-xs font-medium text-gray-500 uppercase">Balance</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#each row.entries as |entry|}}
                                                <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                                                    <td class="px-4 py-2 text-xs text-gray-500 whitespace-nowrap">
                                                        {{format-date-fns entry.date "MMM d, yyyy"}}
                                                    </td>
                                                    <td class="px-4 py-2 text-xs text-gray-500 font-mono whitespace-nowrap">
                                                        {{n-a entry.number}}
                                                    </td>
                                                    <td class="px-4 py-2 text-xs text-gray-700 dark:text-gray-300 max-w-xs truncate">
                                                        {{n-a entry.description}}
                                                    </td>
                                                    <td class="px-4 py-2 text-right text-xs {{if entry.debit_amount 'text-gray-900 dark:text-white' 'text-gray-300 dark:text-gray-600'}}">
                                                        {{if entry.debit_amount (format-currency entry.debit_amount acct.currency) "—"}}
                                                    </td>
                                                    <td class="px-4 py-2 text-right text-xs {{if entry.credit_amount 'text-gray-900 dark:text-white' 'text-gray-300 dark:text-gray-600'}}">
                                                        {{if entry.credit_amount (format-currency entry.credit_amount acct.currency) "—"}}
                                                    </td>
                                                    <td class="px-4 py-2 text-right text-xs font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                                                        {{format-currency entry.running_balance acct.currency}}
                                                    </td>
                                                </tr>
                                            {{/each}}
                                        </tbody>
                                        <tfoot>
                                            <tr class="border-t-2 border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800">
                                                <td colspan="3" class="px-4 py-2 text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Totals</td>
                                                <td class="px-4 py-2 text-right text-xs font-semibold text-gray-900 dark:text-white">
                                                    {{format-currency row.summary.total_debits acct.currency}}
                                                </td>
                                                <td class="px-4 py-2 text-right text-xs font-semibold text-gray-900 dark:text-white">
                                                    {{format-currency row.summary.total_credits acct.currency}}
                                                </td>
                                                <td class="px-4 py-2 text-right text-xs font-semibold text-gray-900 dark:text-white">
                                                    {{format-currency row.summary.net_balance acct.currency}}
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            {{else}}
                                <div class="px-4 py-6 text-center text-xs text-gray-400 bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800">
                                    No journal entries for this account{{#if this.date_from}} in the selected period{{/if}}.
                                </div>
                            {{/if}}
                        {{/if}}
                    </div>
                {{/let}}
            {{/each}}
            <Spacer @height="300px" />
        {{else}}
            <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                <FaIcon @icon="book-open" class="w-12 h-12 mb-3 opacity-30" />
                <p class="text-sm font-medium">No accounts found.</p>
                <p class="text-xs mt-1">Create accounts in the Chart of Accounts to see entries here.</p>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>