<Layout::Resource::Panel
    @resource={{this.journalEntry}}
    @controller={{this}}
    @headerTitle="Create Journal Entry"
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "accounting.journal.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Journal::Form @resource={{this.journalEntry}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>