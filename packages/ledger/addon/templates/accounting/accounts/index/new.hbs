<Layout::Resource::Panel
    @resource={{this.account}}
    @controller={{this}}
    @headerTitle="Create New Account"
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "accounting.accounts.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Account::Form @resource={{this.account}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>