<div class="grid grid-cols-2 lg:grid-cols-4 gap-4" ...attributes>
    <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
        <span class="text-xs text-gray-500 uppercase tracking-wide">Revenue</span>
        <span class="text-xl font-bold text-green-600">
            {{#if this.loadData.isRunning}}
                <span class="text-gray-300 dark:text-gray-600">—</span>
            {{else}}
                {{format-currency (or this.data.kpis.total_revenue.current 0) (or this.data.kpis.total_revenue.currency this.companyCurrency)}}
            {{/if}}
        </span>
    </div>
    <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
        <span class="text-xs text-gray-500 uppercase tracking-wide">Expenses</span>
        <span class="text-xl font-bold text-red-500">
            {{#if this.loadData.isRunning}}
                <span class="text-gray-300 dark:text-gray-600">—</span>
            {{else}}
                {{format-currency (or this.data.kpis.total_expenses.current 0) (or this.data.kpis.total_expenses.currency this.companyCurrency)}}
            {{/if}}
        </span>
    </div>
    <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
        <span class="text-xs text-gray-500 uppercase tracking-wide">Net Income</span>
        <span class="text-xl font-bold text-blue-600">
            {{#if this.loadData.isRunning}}
                <span class="text-gray-300 dark:text-gray-600">—</span>
            {{else}}
                {{format-currency (or this.data.kpis.net_income.current 0) (or this.data.kpis.net_income.currency this.companyCurrency)}}
            {{/if}}
        </span>
    </div>
    <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
        <span class="text-xs text-gray-500 uppercase tracking-wide">Outstanding AR</span>
        <span class="text-xl font-bold text-yellow-600">
            {{#if this.loadData.isRunning}}
                <span class="text-gray-300 dark:text-gray-600">—</span>
            {{else}}
                {{format-currency (or this.data.kpis.outstanding_ar.total 0) (or this.data.kpis.outstanding_ar.currency this.companyCurrency)}}
            {{/if}}
        </span>
    </div>
</div>