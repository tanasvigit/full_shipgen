<div class="flex flex-col" ...attributes>
    <div class="flex flex-row items-center justify-between px-4 py-2 border border-b-0 dark:border-gray-700 border-gray-200 dark:bg-gray-800 bg-gray-50 rounded-t-lg shadow-sm">
        <span class="text-base font-bold text-black dark:text-gray-100">Revenue Chart</span>
    </div>
    <div class="border dark:border-gray-700 border-gray-200 rounded-b-lg shadow-sm p-4 bg-white dark:bg-gray-900">
        {{#if this.loadData.isRunning}}
            <div class="flex items-center justify-center py-10"><Spinner /></div>
        {{else if this.data.length}}
            <div class="space-y-1">
                {{#each this.data as |day|}}
                    <div class="flex items-center gap-2 text-sm">
                        <span class="w-20 text-gray-500 text-xs">{{format-date-fns day.date "yyyy-MM-dd"}}</span>
                        <div class="flex-1 bg-gray-100 dark:bg-gray-700 rounded-full h-2">
                            <div class="bg-blue-500 h-2 rounded-full" style={{html-safe (concat "width: " day.pct "%")}}></div>
                        </div>
                        <span class="w-20 text-right text-gray-700 dark:text-gray-300 text-xs font-medium">{{format-currency day.amount (or day.currency this.companyCurrency)}}</span>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="text-center text-gray-400 py-6 text-sm">No revenue data for this period.</div>
        {{/if}}
    </div>
</div>