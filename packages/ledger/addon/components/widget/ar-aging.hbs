<div class="flex flex-col" ...attributes>
    <div class="flex flex-row items-center justify-between px-4 py-2 border border-b-0 dark:border-gray-700 border-gray-200 dark:bg-gray-800 bg-gray-50 rounded-t-lg shadow-sm">
        <span class="text-base font-bold text-black dark:text-gray-100">AR Aging Summary</span>
    </div>
    <div class="border dark:border-gray-700 border-gray-200 rounded-b-lg shadow-sm p-4 space-y-2 bg-white dark:bg-gray-900">
        {{#if this.loadData.isRunning}}
            <div class="flex items-center justify-center py-6"><Spinner /></div>
        {{else if this.buckets}}
            {{#each-in this.buckets as |bucket total|}}
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400">{{bucket}}</span>
                    <span class="font-semibold text-gray-800 dark:text-gray-200">{{format-currency total this.companyCurrency}}</span>
                </div>
            {{/each-in}}
        {{else}}
            <div class="text-center text-gray-400 py-4 text-sm">No AR aging data.</div>
        {{/if}}
    </div>
</div>