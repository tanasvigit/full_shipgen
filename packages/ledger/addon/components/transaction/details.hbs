<div class="details-wrapper" ...attributes>
    {{! TRANSACTION DETAILS }}
    <ContentPanel @title="Transaction Details" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Transaction Information
            </div>

            <div class="field-info-container">
                <div class="field-name">Reference ID</div>
                <div class="field-value font-mono">{{n-a @resource.public_id}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Status</div>
                <div class="field-value">
                    <Badge @status={{@resource.status}} @color={{@resource.status_badge_color}}>{{@resource.status}}</Badge>
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Type</div>
                <div class="field-value capitalize">{{n-a @resource.type}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Direction</div>
                <div class="field-value capitalize">{{n-a @resource.direction}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Gateway</div>
                <div class="field-value">{{n-a @resource.gateway}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Gateway Transaction ID</div>
                <div class="field-value font-mono">{{n-a @resource.gateway_transaction_id}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Payment Method</div>
                <div class="field-value capitalize">{{n-a @resource.payment_method}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Card</div>
                <div class="field-value">
                    {{#if @resource.payment_method_brand}}
                        {{@resource.payment_method_brand}}
                        ····
                        {{@resource.payment_method_last4}}
                    {{else}}
                        {{n-a null}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Reference</div>
                <div class="field-value font-mono">{{n-a @resource.reference}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Date</div>
                <div class="field-value">{{n-a @resource.createdAt}}</div>
            </div>

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Amounts
            </div>

            <div class="field-info-container">
                <div class="field-name">Amount</div>
                <div class="field-value font-semibold">{{format-currency @resource.amount @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Currency</div>
                <div class="field-value">{{n-a @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Fee</div>
                <div class="field-value">{{format-currency @resource.fee @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Tax</div>
                <div class="field-value">{{format-currency @resource.tax @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Net Amount</div>
                <div class="field-value font-semibold">{{format-currency @resource.net @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Balance After</div>
                <div class="field-value">{{format-currency @resource.balance_after @resource.currency}}</div>
            </div>

            {{#if @resource.exchange_rate}}
                <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                    Settlement
                </div>

                <div class="field-info-container">
                    <div class="field-name">Exchange Rate</div>
                    <div class="field-value">{{n-a @resource.exchange_rate}}</div>
                </div>

                <div class="field-info-container">
                    <div class="field-name">Settled Currency</div>
                    <div class="field-value">{{n-a @resource.settled_currency}}</div>
                </div>

                <div class="field-info-container">
                    <div class="field-name">Settled Amount</div>
                    <div class="field-value">{{format-currency @resource.settled_amount @resource.settled_currency}}</div>
                </div>

                <div class="field-info-container">
                    <div class="field-name">Settled At</div>
                    <div class="field-value">{{n-a @resource.settledAt}}</div>
                </div>
            {{/if}}

        </div>
    </ContentPanel>

    {{! PARTIES }}
    <ContentPanel @title="Parties" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Payer</div>
                <div class="field-value">{{n-a @resource.payer_name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Payee</div>
                <div class="field-value">{{n-a @resource.payee_name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Initiated By</div>
                <div class="field-value">{{n-a @resource.initiator_name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">IP Address</div>
                <div class="field-value font-mono">{{n-a @resource.ip_address}}</div>
            </div>

        </div>
    </ContentPanel>

    {{! FAILURE INFO }}
    {{#if @resource.failure_reason}}
        <ContentPanel @title="Failure Information" @open={{true}} @wrapperClass="bordered-top">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

                <div class="field-info-container">
                    <div class="field-name">Failure Code</div>
                    <div class="field-value font-mono text-red-600">{{n-a @resource.failure_code}}</div>
                </div>

                <div class="field-info-container col-span-2">
                    <div class="field-name">Failure Reason</div>
                    <div class="field-value text-red-600">{{n-a @resource.failure_reason}}</div>
                </div>

            </div>
        </ContentPanel>
    {{/if}}

    {{! DESCRIPTION & NOTES }}
    {{#if (or @resource.description @resource.notes)}}
        <ContentPanel @title="Description & Notes" @open={{true}} @wrapperClass="bordered-top">
            <div class="grid grid-cols-1 gap-2 text-xs dark:text-gray-100">

                {{#if @resource.description}}
                    <div class="field-info-container">
                        <div class="field-name">Description</div>
                        <div class="field-value">{{@resource.description}}</div>
                    </div>
                {{/if}}

                {{#if @resource.notes}}
                    <div class="field-info-container">
                        <div class="field-name">Notes</div>
                        <div class="field-value">{{@resource.notes}}</div>
                    </div>
                {{/if}}

            </div>
        </ContentPanel>
    {{/if}}

    {{! RECORD INFO }}
    <ContentPanel @title="Record Info" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Created</div>
                <div class="field-value">{{n-a @resource.createdAt}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Last Updated</div>
                <div class="field-value">{{n-a @resource.updatedAt}}</div>
            </div>

        </div>
    </ContentPanel>
    <Spacer @height="200px" />
</div>