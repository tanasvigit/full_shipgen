<div>
    {{#if this.loadEvents.isRunning}}
        <div class="flex items-center justify-center py-10"><Spinner /></div>
    {{else}}
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-200 dark:border-gray-700">
                    <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Date</th>
                    <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Event Type</th>
                    <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Gateway Ref</th>
                    <th class="text-right py-2 text-xs font-medium text-gray-500 uppercase">Amount</th>
                    <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Status</th>
                </tr>
            </thead>
            <tbody>
                {{#each this.events as |event|}}
                    <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                        <td class="py-2 text-gray-600 text-xs">{{format-date-fns event.created_at "MMM d, HH:mm"}}</td>
                        <td class="py-2 text-gray-700 dark:text-gray-300 text-xs font-mono">{{event.event_type}}</td>
                        <td class="py-2 text-gray-500 text-xs font-mono truncate max-w-xs">{{event.gateway_reference_id}}</td>
                        <td class="py-2 text-right font-medium text-xs text-gray-900 dark:text-white">{{format-currency event.amount event.currency}}</td>
                        <td class="py-2">
                            <Badge @status={{event.status}} @color={{if (eq event.status "processed") "green" (if (eq event.status "failed") "red" "yellow")}}>
                                {{event.status}}
                            </Badge>
                        </td>
                    </tr>
                {{else}}
                    <tr>
                        <td colspan="5" class="py-4 text-center text-gray-400 text-xs">No webhook events recorded</td>
                    </tr>
                {{/each}}
            </tbody>
        </table>
    {{/if}}
</div>