<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Cash Flow Statement</h2>
        {{#if @data.period}}
            <span class="text-sm text-gray-500">{{@data.period}}</span>
        {{/if}}
    </div>

    {{! Operating Activities }}
    <div>
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">Operating Activities</h3>
        <table class="w-full text-sm">
            <tbody>
                {{#each @data.operating as |item|}}
                    <tr class="border-b border-gray-100 dark:border-gray-700">
                        <td class="py-1.5 text-gray-700 dark:text-gray-300 capitalize">{{item.type}}</td>
                        <td class="py-1.5 text-right font-medium {{if (gt item.net 0) 'text-green-600' 'text-red-600'}}">{{format-currency item.net @data.currency}}</td>
                    </tr>
                {{/each}}
            </tbody>
            <tfoot>
                <tr class="border-t-2 border-gray-300">
                    <td class="py-2 font-semibold text-gray-900 dark:text-white">Net Operating Cash Flow</td>
                    <td class="py-2 text-right font-bold {{if (gt @data.net_operating 0) 'text-green-600' 'text-red-600'}}">{{format-currency @data.net_operating @data.currency}}</td>
                </tr>
            </tfoot>
        </table>
    </div>

    {{! Financing Activities }}
    <div>
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">Financing Activities</h3>
        <table class="w-full text-sm">
            <tbody>
                {{#each @data.financing as |item|}}
                    <tr class="border-b border-gray-100 dark:border-gray-700">
                        <td class="py-1.5 text-gray-700 dark:text-gray-300 capitalize">{{item.type}}</td>
                        <td class="py-1.5 text-right font-medium {{if (gt item.net 0) 'text-green-600' 'text-red-600'}}">{{format-currency item.net @data.currency}}</td>
                    </tr>
                {{/each}}
            </tbody>
            <tfoot>
                <tr class="border-t-2 border-gray-300">
                    <td class="py-2 font-semibold text-gray-900 dark:text-white">Net Financing Cash Flow</td>
                    <td class="py-2 text-right font-bold {{if (gt @data.net_financing 0) 'text-green-600' 'text-red-600'}}">{{format-currency @data.net_financing @data.currency}}</td>
                </tr>
            </tfoot>
        </table>
    </div>

    {{! Net Change }}
    <div class="border-t-2 border-gray-400 pt-4">
        <div class="flex justify-between items-center">
            <span class="text-base font-bold text-gray-900 dark:text-white">Net Change in Cash</span>
            <span class="text-base font-bold {{if (gt @data.net_change 0) 'text-green-600' 'text-red-600'}}">
                {{format-currency @data.net_change @data.currency}}
            </span>
        </div>
    </div>
</div>