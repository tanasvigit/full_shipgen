<div ...attributes>
    {{#if this.loadTransactions.isRunning}}
        <div class="flex items-center justify-center py-8">
            <Spinner />
        </div>
    {{else if (eq this.transactions.length 0)}}
        <div class="flex flex-col items-center justify-center py-12 text-gray-400 dark:text-gray-500">
            <FaIcon @icon="receipt" @size="2x" class="mb-3 opacity-40" />
            <p class="text-sm">{{t "invoice.no-transactions"}}</p>
        </div>
    {{else}}
        <Table @rows={{this.transactions}} @columns={{this.columns}} />
    {{/if}}
</div>