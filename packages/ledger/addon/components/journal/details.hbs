<div class="details-wrapper" ...attributes>
    {{! JOURNAL ENTRY DETAILS }}
    <ContentPanel @title="Journal Entry" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Entry Information
            </div>

            <div class="field-info-container">
                <div class="field-name">Entry Number</div>
                <div class="field-value font-mono">{{n-a @resource.number}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Type</div>
                <div class="field-value">{{n-a (titleize @resource.type)}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Entry Date</div>
                <div class="field-value">{{n-a @resource.entryDate}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Source</div>
                <div class="field-value">
                    <Badge @color={{if @resource.is_system_entry "blue" "gray"}}>{{@resource.entry_source}}</Badge>
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Amount</div>
                <div class="field-value font-semibold">{{format-currency @resource.amount @resource.currency}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Currency</div>
                <div class="field-value">{{n-a @resource.currency}}</div>
            </div>

            {{#if @resource.description}}
                <div class="field-info-container col-span-2">
                    <div class="field-name">Description</div>
                    <div class="field-value">{{@resource.description}}</div>
                </div>
            {{/if}}

        </div>
    </ContentPanel>

    {{! DOUBLE-ENTRY }}
    <ContentPanel @title="Double-Entry" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Debit
            </div>

            <div class="field-info-container">
                <div class="field-name">Debit Account</div>
                <div class="field-value">{{n-a @resource.debit_account_name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Debit Account Code</div>
                <div class="field-value font-mono">{{n-a @resource.debit_account_code}}</div>
            </div>

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Credit
            </div>

            <div class="field-info-container">
                <div class="field-name">Credit Account</div>
                <div class="field-value">{{n-a @resource.credit_account_name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Credit Account Code</div>
                <div class="field-value font-mono">{{n-a @resource.credit_account_code}}</div>
            </div>

        </div>
    </ContentPanel>

    {{! RECORD INFO }}
    <ContentPanel @title="Record Info" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">

            <div class="field-info-container">
                <div class="field-name">Internal ID</div>
                <div class="field-value font-mono">{{n-a @resource.public_id}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Created</div>
                <div class="field-value">{{n-a @resource.createdAt}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">Last Updated</div>
                <div class="field-value">{{n-a @resource.updatedAt}}</div>
            </div>

        </div>
    </ContentPanel>
    <Spacer @height="200px" />
</div>